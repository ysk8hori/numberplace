{
  "extends": ["config:recommended"],
  "baseBranchPatterns": ["main"],
  "timezone": "Asia/Tokyo",
  "schedule": ["after 5pm and before 10pm on Thursday"],
  "minimumReleaseAge": "7 days",
  "rangeStrategy": "pin",
  "packageRules": [
    {
      "matchUpdateTypes": ["major", "minor"],
      "labels": ["TypeScript"],
      "matchPackageNames": ["typescript"],
      "groupName": "TypeScript"
    },
    {
      "groupName": "React & Sentry related packages",
      "labels": ["React"],
      "matchPackageNames": [
        "react",
        "react-dom",
        "react-icons",
        "/^@sentry/"
      ]
    },
    {
      "groupName": "Vite related packages",
      "labels": ["Vite"],
      "matchPackageNames": ["vite", "/^@vitejs/"]
    },
    {
      "groupName": "Storybook & Chromatic related packages",
      "labels": ["Storybook"],
      "matchPackageNames": [
        "storybook",
        "chromatic",
        "/^@storybook/",
        "/^@chromatic-com/"
      ]
    },
    {
      "groupName": "ESLint & Prettier related packages",
      "labels": ["ESLint"],
      "matchPackageNames": [
        "eslint",
        "eslint-config-prettier",
        "prettier",
        "/^@typescript-eslint/",
        "/^eslint-plugin/"
      ]
    },
    {
      "groupName": "Testing related packages",
      "labels": ["Testing"],
      "matchPackageNames": [
        "/^@testing-library/",
        "vitest",
        "/^@vitest/",
        "jsdom"
      ]
    },
    {
      "groupName": "Styles and assets tools",
      "labels": ["Styles"],
      "matchPackageNames": [
        "postcss",
        "postcss-import",
        "postcss-loader",
        "sass",
        "sass-loader",
        "tailwindcss",
        "autoprefixer"
      ]
    },
    {
      "groupName": "Babel related packages",
      "matchPackageNames": [
        "/^@babel/"
      ]
    },
    {
      "groupName": "All minor and patch dependencies",
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["UPDATE-MINOR&PATCH"],
      "matchPackageNames": [
        "!typescript",
        "!react",
        "!react-dom",
        "!react-icons",
        "!/^@sentry/",
        "!vite",
        "!/^@vitejs/",
        "!storybook",
        "!chromatic",
        "!/^@storybook/",
        "!/^@chromatic-com/",
        "!eslint",
        "!eslint-config-prettier",
        "!prettier",
        "!/^@typescript-eslint/",
        "!/^eslint-plugin/",
        "!/^@testing-library/",
        "!vitest",
        "!/^@vitest/",
        "!jsdom",
        "!postcss",
        "!postcss-import",
        "!postcss-loader",
        "!sass",
        "!sass-loader",
        "!tailwindcss",
        "!autoprefixer",
        "!/^@babel/"
      ]
    }
  ],
  "automerge": true,
  "ignoreDeps": ["styled-components"]
}
